@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h1 class="mb-3">@ViewData["Title"]</h1>
        <p class="text-muted">
            TechMoves GLMS is committed to protecting user and client information within the system.
        </p>

        <hr />

        <h5>Information Usage</h5>
        <p>
            The system stores client, contract, and service request data strictly for logistics management,
            reporting, and operational workflow purposes.
        </p>

        <h5>Document Storage</h5>
        <p>
            Uploaded agreement documents are stored securely within the application environment and are used
            only for contract administration.
        </p>

        <h5>Access Control</h5>
        <p>
            Access to sensitive operational information should be restricted to authorized users such as
            administrators, finance personnel, and contract managers.
        </p>

        <h5>Data Accuracy</h5>
        <p>
            Users are responsible for ensuring that client details, contract statuses, and service request
            information entered into the system are accurate and up to date.
        </p>
    </div>
</div>